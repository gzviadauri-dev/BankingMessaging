<?xml version="1.0" encoding="utf-8"?>
<!--
  Local development:
    Set the GITHUB_PACKAGES_TOKEN environment variable to a GitHub PAT
    with `read:packages` scope for gzviadauri-dev.

  GitHub Actions:
    The CI workflow injects GITHUB_TOKEN automatically — no extra setup needed.
-->
<configuration>
  <packageSources>
    <add key="nuget.org"         value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-gzviadauri" value="https://nuget.pkg.github.com/gzviadauri-dev/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-gzviadauri>
      <add key="Username"          value="gzviadauri-dev" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-gzviadauri>
  </packageSourceCredentials>
</configuration>

<?xml version="1.0" encoding="utf-8"?>
<!--
  ── Local development ────────────────────────────────────────────────────────
  Set the GITHUB_PACKAGES_TOKEN environment variable to a GitHub PAT
  with `read:packages` scope, then restore normally:

    $env:GITHUB_PACKAGES_TOKEN = "ghp_xxxx"   # PowerShell
    export GITHUB_PACKAGES_TOKEN="ghp_xxxx"   # bash/zsh
    dotnet restore

  ── GitHub Actions ───────────────────────────────────────────────────────────
  Add a repository secret named NUGET_TOKEN containing a PAT with
  `read:packages` scope (Settings → Secrets and variables → Actions → New).
  The CI workflow sets NUGET_AUTH_TOKEN from that secret; NuGet picks it up
  automatically from the environment — no `dotnet nuget update source` needed.

  Why not GITHUB_TOKEN?
  GITHUB_TOKEN is scoped to the current repository only. Company.Observability
  lives in a different repository under the same account, so GITHUB_TOKEN
  always returns 403. A PAT with read:packages has cross-repo access.
-->
<configuration>
  <packageSources>
    <add key="nuget.org"         value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-gzviadauri" value="https://nuget.pkg.github.com/gzviadauri-dev/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-gzviadauri>
      <add key="Username"          value="gzviadauri-dev" />
      <!-- NUGET_AUTH_TOKEN is the standard env var read by NuGet in CI.
           Locally, set GITHUB_PACKAGES_TOKEN and it falls back to that. -->
      <add key="ClearTextPassword" value="%NUGET_AUTH_TOKEN%" />
    </github-gzviadauri>
  </packageSourceCredentials>
</configuration>

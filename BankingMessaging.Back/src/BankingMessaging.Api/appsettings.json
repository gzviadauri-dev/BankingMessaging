{
  "ConnectionStrings": {
    "Default": "Server=localhost\\SQLEXPRESS;Database=Banking;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Observability": {
    "ServiceName": "BankingMessaging.Api",
    "ServiceVersion": "1.0.0",
    "Logging": {
      "MinimumLevel": "Information",
      "ExcludePaths": [ "/health", "/metrics", "/favicon.ico" ],
      "SampleSuccessRate": 1.0,
      "EnableConsoleOutput": true,
      "CorrelationHeaderName": "X-Correlation-Id",
      "Graylog": {
        "Enabled": false,
        "Host": "graylog",
        "Port": 12201,
        "Protocol": "udp",
        "Facility": "BankingMessaging.Api"
      },
      "RateLimit": {
        "Enabled": true,
        "MaxPerWindow": 100,
        "WindowSeconds": 60
      }
    },
    "Telemetry": {
      "Enabled": true,
      "Tracing": {
        "Enabled": true,
        "SamplingRatio": 1.0,
        "ExcludePaths": [ "/health", "/metrics" ]
      },
      "Metrics": {
        "Enabled": true,
        "PrometheusEnabled": false
      },
      "Otlp": {
        "Enabled": true,
        "Endpoint": "http://localhost:4317",
        "Protocol": "grpc"
      }
    },
    "Redaction": {
      "SensitiveKeys": [ "accountNumber", "iban" ]
    }
  },
  "AllowedHosts": "*"
}

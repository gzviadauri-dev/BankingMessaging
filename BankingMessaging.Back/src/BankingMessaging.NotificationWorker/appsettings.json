{
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Observability": {
    "ServiceName": "BankingMessaging.NotificationWorker",
    "ServiceVersion": "1.0.0",
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsoleOutput": true,
      "Graylog": {
        "Enabled": false,
        "Host": "graylog",
        "Port": 12201,
        "Protocol": "udp",
        "Facility": "BankingMessaging.NotificationWorker"
      },
      "RateLimit": {
        "Enabled": true,
        "MaxPerWindow": 100,
        "WindowSeconds": 60
      }
    },
    "Telemetry": {
      "Enabled": true,
      "Tracing": {
        "Enabled": true,
        "SamplingRatio": 1.0
      },
      "Metrics": {
        "Enabled": true,
        "PrometheusEnabled": false
      },
      "Otlp": {
        "Enabled": true,
        "Endpoint": "http://localhost:4317",
        "Protocol": "grpc"
      }
    },
    "Redaction": {
      "SensitiveKeys": [ "accountNumber", "iban" ]
    }
  }
}
